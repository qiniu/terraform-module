# ============================================================================
# OpenClaw Terraform 配置示例
# ============================================================================
# 复制此文件为 terraform.tfvars 并填写实际值
# 基于七牛云 LAS 社区镜像 OpenClaw，开箱即用
# ============================================================================

# ============================================================================
# 实例配置（必填）
# ============================================================================

# 实例密码（root 和 openclaw 用户共用）
# 要求：不少于 8 位，必须同时包含字母、数字和特殊符号
root_password = "YourSecurePassword123!"

# ============================================================================
# 实例规格（可选，有默认值）
# ============================================================================

# ECS 实例规格
# instance_type = "ecs.t1.c4m8"

# 系统盘大小（GiB）
# system_disk_size = 50

# 公网带宽（Mbps）
# internet_max_bandwidth = 100

# ============================================================================
# 七牛 MaaS 配置（必填）
# ============================================================================

# 七牛 MaaS API Key（从 https://portal.qiniu.com/ai-inference/api-key 获取）
qiniu_maas_api_key = "sk-your-qiniu-api-key"

# 可选微信绑定串，格式：botid|token|savedAt|baseUrl|userId
# wx_secret = "xxxxxx-im-bot|xxxxxx-im-bot@im.bot:0xxxx|2026-01-01T00:00:00.000Z|https://ilinkai.weixin.qq.com|xxxxxx@im.wechat"

# 默认模型
# 可选值：minimax/minimax-m2.5、deepseek/deepseek-chat、qwen/qwen-max 等
default_model = "minimax/minimax-m2.5"

# ============================================================================
# 高级配置（可选）
# ============================================================================

# Gateway 端口
# gateway_port = 18789

# 实例名称前缀
# instance_name_prefix = "openclaw"

# 镜像名称前缀（用于筛选匹配的社区镜像）
# image_name_prefix = "OpenClaw-v2026.3.8"

# 是否将 Dashboard 暴露到公网
# expose_dashboard = false

# 是否禁用设备认证
# disable_device_auth = false
