$schema: "https://json-schema.org/draft-07/schema"
type: object
properties:
{% if vars.show_instance_type %}
  instance_type:
    type: string
    description: "实例规格"
    default: "ecs.t1.c4m8"
    enum:
      - "ecs.t1.c1m2"
      - "ecs.t1.c2m4"
      - "ecs.t1.c4m8"
      - "ecs.t1.c8m16"
      - "ecs.t1.c12m24"
      - "ecs.t1.c16m32"
      - "ecs.t1.c24m48"
      - "ecs.t1.c32m64"
      - "ecs.c1.c1m2"
      - "ecs.c1.c2m4"
      - "ecs.c1.c4m8"
      - "ecs.c1.c8m16"
      - "ecs.c1.c12m24"
      - "ecs.c1.c16m32"
      - "ecs.c1.c24m48"
      - "ecs.c1.c32m64"
      - "ecs.g1.c16m120"
      - "ecs.g1.c32m240"
{% endif %}

  system_disk_type:
    type: string
    description: |
      系统盘类型：
        1. local.ssd：本地 SSD 磁盘，提供更高的 I/O 性能，适合对性能有较高要求的应用场景。
        2. cloud.ssd：云盘 SSD 磁盘，提供稳定的性能和数据持久性，适合大多数应用场景。
{% if vars.system_disk_type_const != nil %}
    readOnly: true
    default: "{{ vars.system_disk_type_const }}"
    enum:
      - "{{ vars.system_disk_type_const }}"
{% else %}
    default: "cloud.ssd"
    enum:
      - "cloud.ssd"
      - "local.ssd"
{% endif %}

  system_disk_size:
    type: integer
    description: "系统盘大小（GiB）"
{% if vars.system_disk_size_const == nil %}
    default: 50
    minimum: 20
    maximum: 500
    multipleOf: 10 # 系统盘大小必须是 10 的倍数
{% else %}
    readOnly: true
    default: {{ vars.system_disk_size_const }}
{% endif %}

  internet_charge_type:
    type: string
    description: |
      互联网出网带宽计费方式:
        1. Bandwidth：按带宽计费，按照实例的公网带宽大小进行计费，适合对带宽需求较为稳定的场景。
        2. PeakBandwidth：按峰值带宽计费，按照实例的公网带宽峰值进行计费，适合对带宽需求有较大波动的场景。
        3. Traffic：按流量计费，按照实例的公网流量使用量进行计费，适合对带宽需求不稳定且流量使用量较大的场景。
{% if vars.internet_charge_type_const != nil %}
    default: "{{ vars.internet_charge_type_const }}"
    enum:
      - "{{ vars.internet_charge_type_const }}"
    readOnly: true
{% else %}
    default: "PeakBandwidth"
    enum:
      - "Bandwidth"
      - "PeakBandwidth"
      - "Traffic"
{% endif %}

  internet_max_bandwidth:
    type: integer
    description: |
      公网最大带宽（Mbps），取值范围 1-300
      - 当 internet_charge_type 为 PeakBandwidth 时，取值仅能选择为 50、100、200
{% if vars.internet_max_bandwidth_const != nil %}
    default: {{ vars.internet_max_bandwidth_const }}
    readOnly: true
{% else %}
    default: 100
    minimum: 1
    maximum: 300
{% endif %}

  root_password:
    type: string
    format: "password"
    description: "实例 root 用户密码（至少 8 个字符，需同时包含字母、数字和特殊符号）"
    minLength: 8
    allOf:
      - pattern: "[A-Za-z]"
      - pattern: "[0-9]"
      - pattern: "[^A-Za-z0-9]"

  qiniu_maas_api_key:
    type: string
    format: "password"
    description: "七牛 MaaS API 密钥（从 https://portal.qiniu.com/ai-inference/api-key 获取）"
    minLength: 1

  default_model:
    type: string
    description: "使用的 AI 模型（如 minimax/minimax-m2.5、deepseek/deepseek-chat、qwen/qwen-max 等）"
    default: "minimax/minimax-m2.5"

  gateway_port:
    type: integer
    description: "Gateway 服务端口"
    default: 18789
    minimum: 1
    maximum: 65535

  expose_dashboard:
    type: boolean
    description: |
      是否将 Dashboard 公开到公网
      - 部署完成后，将直接输出 Dashboard 的公网访问地址，用户可以直接访问和管理 OpenClaw。
    default: false

  disable_device_auth:
    type: boolean
    description: |
      是否禁用设备认证
      - false（默认）：启用设备认证，只有通过认证的设备才能访问 OpenClaw Gateway，提供更高的安全性。
      - true：禁用设备认证，任何设备都可以直接访问进 OpenClaw Gateway，适合对安全性要求不高且需要快速部署的场景。
    default: false

{% if vars.show_cost_period_month %}
  cost_period:
    type: integer
    description: "购买时长（月）"
    default: 1
    minimum: 1
    maximum: 36
{% endif %}

{% if vars.show_cost_period_year %}
  # 当前portal暂不支持年付
  cost_period:
    type: integer
    description: "购买时长（年）"
    default: 1
    minimum: 1
    maximum: 3
{% endif %}

required:
  - root_password
  - qiniu_maas_api_key

{% if vars.internet_max_bandwidth_const == nil %}
dependencies:
  internet_charge_type:
    oneOf:
      - properties:
          # 当计费方式是PeakBandwidth时，最大带宽只能是50、100、200
          internet_charge_type:
            const: "PeakBandwidth"
          internet_max_bandwidth:
            enum: [50, 100, 200]
      - properties:
          # 当计费方式是Bandwidth或Traffic时，最大带宽可以是1-300的任意整数
          # 不过这里直接和portal前端一样，限制为几个常用的带宽档位，避免出现过多不常见的带宽选项
          internet_charge_type:
            enum: ["Bandwidth", "Traffic"]
          internet_max_bandwidth:
            enum: [1, 2, 3, 4, 5, 10, 20, 50, 100, 200, 300]
{% endif %}

x-input-groups:
  - name: "七牛 LAS 配置"
    inputs:
{% if vars.show_instance_type %}
      - instance_type
{% endif %}
      - system_disk_type
      - system_disk_size
      - internet_charge_type
      - internet_max_bandwidth
      - root_password

  - name: "七牛 MaaS 配置"
    inputs:
      - qiniu_maas_api_key
      - default_model

  - name: "OpenClaw Gateway 配置"
    inputs:
      - gateway_port
      - expose_dashboard
      - disable_device_auth

{% if vars.show_cost_period_month or vars.show_cost_period_year %}
  - name: "付费配置"
    inputs:
      - cost_period
{% endif %}